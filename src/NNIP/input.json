{
    "_comment": "DeePMD-kit training input for 9-element Al alloy NNIP",
    "model": {
        "type_map": ["Al", "Zn", "Mg", "Mn", "Cu", "Si", "Cr", "Fe", "Ti"],
        "descriptor": {
            "type": "se_e2_a",
            "rcut_smth": 0.5,
            "rcut": 6.0,
            "sel": [80, 80, 80, 80, 80, 80, 80, 80, 80],
            "neuron": [25, 50, 100],
            "resnet_dt": false,
            "axis_neuron": 16,
            "seed": 1
        },
        "fitting_net": {
            "neuron": [240, 240, 240],
            "resnet_dt": true,
            "seed": 1
        }
    },
    "learning_rate": {
        "type": "exp",
        "decay_steps": 5000,
        "start_lr": 0.001,
        "stop_lr": 1e-8
    },
    "loss": {
        "type": "ener",
        "start_pref_e": 0.02,
        "limit_pref_e": 1.0,
        "start_pref_f": 1000,
        "limit_pref_f": 1.0,
        "start_pref_v": 0.02,
        "limit_pref_v": 1.0
    },
    "training": {
        "training_data": {
            "systems": ["data/training/deepmd/"],
            "batch_size": "auto"
        },
        "validation_data": {
            "systems": ["data/validation/deepmd/"],
            "batch_size": "auto"
        },
        "numb_steps": 400000,
        "seed": 1,
        "disp_file": "lcurve.out",
        "disp_freq": 1000,
        "save_freq": 10000
    }
}
